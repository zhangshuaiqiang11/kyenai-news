# Domains
FRONTEND_DOMAIN=www.kyenai.com
APEX_DOMAIN=kyenai.com
API_DOMAIN=api.kyenai.com

# Frontend build/runtime URLs
NEXT_PUBLIC_SITE_URL=https://www.kyenai.com
NEXT_PUBLIC_API_BASE_URL=https://api.kyenai.com
API_BASE_URL=http://backend:8000

# Backend CORS
CORS_ALLOW_ORIGINS=https://www.kyenai.com,https://api.kyenai.com,http://localhost:3000,http://127.0.0.1:3000

# Database
POSTGRES_USER=geo
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=geo_portal
DATABASE_URL=postgresql://geo:replace-with-strong-password@postgres:5432/geo_portal

# Redis
REDIS_URL=redis://redis:6379/0

# Third-party integrations
OPENAI_API_KEY=replace-with-openai-key
GOOGLE_APPLICATION_CREDENTIALS_HOST_PATH=/opt/seo/secrets/google-application-credentials.json
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-application-credentials.json
GOOGLE_OAUTH_REFRESH_TOKEN=replace-with-google-oauth-refresh-token
GSC_SITE_URL=https://www.kyenai.com/
GA4_PROPERTY_ID=replace-with-ga4-property-id
BING_WEBMASTER_API_KEY=replace-with-bing-webmaster-api-key
BING_SITE_URL=https://www.kyenai.com
INDEXNOW_KEY=replace-with-indexnow-key
INDEXNOW_HOST=www.kyenai.com
PAGESPEED_API_KEY=replace-with-pagespeed-api-key
NEXT_PUBLIC_GA_ID=replace-with-ga4-measurement-id
NEXT_PUBLIC_EDITORIAL_EMAIL=editorial@your-production-domain.com
